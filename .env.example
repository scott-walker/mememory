# PostgreSQL connection (required)
# For bundled Docker mode, this matches docker-compose defaults.
# For external Postgres, replace with your own connection string.
# Requires: PostgreSQL >= 14 with pgvector extension.
DATABASE_URL=postgres://mememory:mememory@localhost:5432/mememory?sslmode=disable

# Data directory (optional)
# If unset, mememory CLI auto-resolves to OS-standard location:
#   Linux:   ~/.local/share/mememory
#   macOS:   ~/Library/Application Support/mememory
#   Windows: %LOCALAPPDATA%\mememory
# DATA_DIR=/path/to/custom/dir

# Port mappings (optional)
POSTGRES_PORT=5432
OLLAMA_PORT=11434
ADMIN_PORT=4200
